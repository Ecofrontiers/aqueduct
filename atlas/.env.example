# Aqueduct — minimal env for a fresh clone (see README Quickstart).
# The app degrades gracefully: without Supabase keys the inherited Atlas asset
# registry is empty but the Aqueduct economy, coop seats, tour, and ledger all run.

# REQUIRED — the map
VITE_MAPBOX_ACCESS_TOKEN=

# OPTIONAL — the inherited Regen Atlas asset registry (505 assets / 224 actions)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OPTIONAL — wallet connect UI (Connect Wallet button)
VITE_WC_PROJECT_ID=
